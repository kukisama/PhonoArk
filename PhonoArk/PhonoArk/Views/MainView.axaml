<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             xmlns:views="using:PhonoArk.Views"
             xmlns:animation="using:Avalonia.Animation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.MainView"
             x:CompileBindings="False"
             x:DataType="vm:MainViewModel">
  <UserControl.Styles>
    <Style Selector="Button.mobile-nav">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="8,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Background" Value="#00000000"/>
      <Setter Property="BorderBrush" Value="#00000000"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.06"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.06"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.mobile-nav:pressed">
      <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}"/>
    </Style>

    <Style Selector="Button.mobile-nav.active">
      <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppNavActiveTextBrush}"/>
    </Style>

    <Style Selector="Button.mobile-nav.active:pressed">
      <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppNavActiveTextBrush}"/>
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid Background="{DynamicResource AppPageBackgroundBrush}">
    <Border Background="#FFF7FBFF" Margin="0,0,0,0">
      <Grid x:Name="MainLayoutGrid" Margin="20" ColumnDefinitions="260,*" ColumnSpacing="18" Classes="main-layout">
        <!-- Navigation Sidebar -->
        <Border x:Name="NavPanelBorder" Grid.Column="0" Classes="flutter-card flutter-card-lift nav-panel">
          <Grid>
          <ScrollViewer x:Name="DesktopNavScroll" Classes="nav-scroll"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="DesktopNavStack" Spacing="6" Classes="nav-stack">
            <TextBlock x:Name="BrandTitleText" Text="{Binding [AppName], Source={StaticResource Loc}}"
                       Classes="flutter-title"
                       Margin="4,4,4,2"/>
            <TextBlock x:Name="BrandSubtitleText" Text="{Binding [AppSubtitle], Source={StaticResource Loc}}"
                       Classes="flutter-caption"
                       Margin="4,0,4,14"/>

            <Button Content="{Binding [NavIpaChart], Source={StaticResource Loc}}"
                    Click="OnIpaChartClick"
                    HorizontalAlignment="Stretch"
                  Classes="flutter-nav"
                    Classes.active="{Binding IsIpaChartSelected}">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🔤" Classes="flutter-icon"/>
                <TextBlock Text="{Binding [NavIpaChart], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Content="{Binding [NavExam], Source={StaticResource Loc}}"
                    Click="OnExamClick"
                    HorizontalAlignment="Stretch"
                  Classes="flutter-nav"
                    Classes.active="{Binding IsExamSelected}">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🧪" Classes="flutter-icon"/>
                <TextBlock Text="{Binding [NavExam], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Content="{Binding [NavHistory], Source={StaticResource Loc}}"
                    Click="OnHistoryClick"
                    HorizontalAlignment="Stretch"
                  Classes="flutter-nav"
                    Classes.active="{Binding IsHistorySelected}">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🕘" Classes="flutter-icon"/>
                <TextBlock Text="{Binding [NavHistory], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="DesktopComingSoonButton" Content="{Binding [NavWordLearning], Source={StaticResource Loc}}"
                    IsEnabled="False"
                    HorizontalAlignment="Stretch"
                    Classes="flutter-nav"
                    ToolTip.Tip="{Binding [ComingSoon], Source={StaticResource Loc}}">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="📚" Classes="flutter-icon"/>
                <TextBlock Text="{Binding [NavWordLearning], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Content="{Binding [NavSettings], Source={StaticResource Loc}}"
                    Click="OnSettingsClick"
                    HorizontalAlignment="Stretch"
                        Classes="flutter-nav"
                  Classes.active="{Binding IsSettingsSelected}"
                    Margin="0,14,0,0">
              <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="⚙️" Classes="flutter-icon"/>
                    <TextBlock Text="{Binding [NavSettings], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
          </ScrollViewer>

                    <UniformGrid x:Name="MobileBottomNavGrid"
                           IsVisible="False"
                           Rows="1"
                           Columns="4"
                           Margin="2">
                      <Button Content="{Binding [NavIpaChart], Source={StaticResource Loc}}"
                        Click="OnIpaChartClick"
                        Classes="mobile-nav"
                        Classes.active="{Binding IsIpaChartSelected}"/>
                      <Button Content="{Binding [NavExam], Source={StaticResource Loc}}"
                        Click="OnExamClick"
                        Classes="mobile-nav"
                        Classes.active="{Binding IsExamSelected}"/>
                      <Button Content="{Binding [NavHistory], Source={StaticResource Loc}}"
                        Click="OnHistoryClick"
                        Classes="mobile-nav"
                        Classes.active="{Binding IsHistorySelected}"/>
                      <Button Content="{Binding [NavSettings], Source={StaticResource Loc}}"
                        Click="OnSettingsClick"
                        Classes="mobile-nav"
                        Classes.active="{Binding IsSettingsSelected}"/>
                    </UniformGrid>
                    </Grid>
        </Border>

        <!-- Content Area -->
        <Border x:Name="ContentPanelBorder" Grid.Column="1" Classes="flutter-card content-panel" Padding="12">
          <TransitioningContentControl x:Name="MainContentHost" Content="{Binding CurrentView}">
            <TransitioningContentControl.PageTransition>
              <animation:CrossFade Duration="0:0:0.22"/>
            </TransitioningContentControl.PageTransition>
            <TransitioningContentControl.DataTemplates>
              <DataTemplate DataType="vm:IpaChartViewModel">
                <views:IpaChartView/>
              </DataTemplate>
              <DataTemplate DataType="vm:ExamViewModel">
                <views:ExamView/>
              </DataTemplate>
              <DataTemplate DataType="vm:SettingsViewModel">
                <views:SettingsView/>
              </DataTemplate>
              <DataTemplate DataType="vm:ExamHistoryViewModel">
                <views:ExamHistoryView/>
              </DataTemplate>

            </TransitioningContentControl.DataTemplates>
          </TransitioningContentControl>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
