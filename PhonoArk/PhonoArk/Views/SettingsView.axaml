<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.SettingsView"
             x:CompileBindings="False"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="14" MaxWidth="760">
      <TextBlock Text="{Binding [SettingsTitle], Source={StaticResource Loc}}" Classes="flutter-title"/>
      <TextBlock Text="{Binding [SettingsIntro], Source={StaticResource Loc}}" Classes="flutter-caption" Margin="0,0,0,6"/>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding [VersionLabel], Source={StaticResource Loc}}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding AppVersion}" FontSize="16" VerticalAlignment="Center" Opacity="0.85"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="🔗" FontSize="14" VerticalAlignment="Center"/>
            <Button Content="GitHub"
                    Classes="flutter-link"
                    Command="{Binding OpenGitHubCommand}"
                    Padding="0" Margin="0"
                    FontSize="14"
                    Cursor="Hand"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding [DefaultAccent], Source={StaticResource Loc}, StringFormat='🎤 {0}'}" FontSize="16" FontWeight="SemiBold"/>
          <ComboBox Classes="flutter-input"
                    ItemsSource="{Binding AccentOptions}"
                    SelectedItem="{Binding SelectedAccentOption}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding [Language], Source={StaticResource Loc}, StringFormat='🌐 {0}'}" FontSize="16" FontWeight="SemiBold"/>
          <ComboBox Classes="flutter-input"
                    ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding SelectedLanguageOption}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding [Volume], Source={StaticResource Loc}, StringFormat='🔊 {0}'}" FontSize="16" FontWeight="SemiBold"/>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Slider Grid.Column="0"
                    Value="{Binding Volume}"
                    Minimum="0"
                    Maximum="1"
                    TickFrequency="0.05"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Volume, StringFormat='{}{0:P0}'}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding [DefaultExamQuestions], Source={StaticResource Loc}, StringFormat='🧪 {0}'}" FontSize="16" FontWeight="SemiBold"/>
          <NumericUpDown Classes="flutter-input"
                        Value="{Binding ExamQuestionCount}"
                        Minimum="5"
                        Maximum="50"
                        Increment="5"/>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding [ExperienceSwitch], Source={StaticResource Loc}}" FontSize="16" FontWeight="SemiBold"/>

          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="{Binding [DarkMode], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding DarkMode}"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="{Binding [EnableStudyReminders], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding RemindersEnabled}"/>
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="flutter-card flutter-card-lift">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding [VoiceDiagnostics], Source={StaticResource Loc}}" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding VoiceDiagnosticsSummary}" TextWrapping="Wrap" Classes="flutter-caption"/>

          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6" Margin="0,2,0,4">
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{Binding [VoicePlatformLabel], Source={StaticResource Loc}}"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VoiceDiagnosticsPlatform}" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="{Binding [VoiceRequestedCultureLabel], Source={StaticResource Loc}}"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VoiceDiagnosticsRequestedCulture}" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="{Binding [VoiceSelectedVoiceLabel], Source={StaticResource Loc}}"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VoiceDiagnosticsSelectedVoice}" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="{Binding [VoiceDetailCountLabel], Source={StaticResource Loc}}"
                       FontWeight="SemiBold"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding VoiceDiagnosticsCount}"/>
          </Grid>

          <Button Content="{Binding [RunVoiceDiagnostics], Source={StaticResource Loc}}"
                  Classes="flutter-secondary"
                  Command="{Binding RunVoiceDiagnosticsCommand}"
                  HorizontalAlignment="Left"/>

          <Expander Header="{Binding [VoiceDiagnosticsDetails], Source={StaticResource Loc}}">
            <ItemsControl ItemsSource="{Binding VoiceDiagnostics}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Opacity="0.8"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Expander>
        </StackPanel>
      </Border>

      <Button Content="{Binding [SaveSettings], Source={StaticResource Loc}}"
              Classes="flutter-primary"
              Command="{Binding SaveSettingsCommand}"
              HorizontalAlignment="Stretch"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
