<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.IpaChartView"
             x:Name="Root"
             x:CompileBindings="False"
             x:DataType="vm:IpaChartViewModel">

  <UserControl.Styles>
    <Style Selector="UserControl.mobile Button.flutter-tile">
      <Setter Property="MinWidth" Value="72"/>
      <Setter Property="MinHeight" Value="60"/>
      <Setter Property="FontSize" Value="26"/>
      <Setter Property="Padding" Value="14,10"/>
    </Style>

    <Style Selector="UserControl.mobile Button.flutter-word">
      <Setter Property="Padding" Value="12"/>
      <Setter Property="MinHeight" Value="54"/>
    </Style>

    <Style Selector="Button.favorite-toggle">
      <Setter Property="MinWidth" Value="40"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="26"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Background" Value="#00000000"/>
      <Setter Property="BorderBrush" Value="#00000000"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe UI Emoji, Noto Sans Symbols, Arial Unicode MS, sans-serif"/>
      <Setter Property="Foreground" Value="#B88900"/>
    </Style>

    <Style Selector="Button.favorite-toggle.active">
      <Setter Property="Foreground" Value="#EAB308"/>
      <Setter Property="Background" Value="#1AF59E0B"/>
      <Setter Property="BorderBrush" Value="#44F59E0B"/>
    </Style>

    <Style Selector="Button.phoneme-hero">
      <Setter Property="Background" Value="#00000000"/>
      <Setter Property="BorderBrush" Value="#00000000"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="MinWidth" Value="110"/>
      <Setter Property="MinHeight" Value="86"/>
    </Style>

    <Style Selector="Button.word-chip">
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="Margin" Value="0,0,8,8"/>
      <Setter Property="MinHeight" Value="0"/>
    </Style>

    <Style Selector="Button.flutter-tile.active">
      <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppNavActiveTextBrush}"/>
    </Style>

    <Style Selector="Button.flutter-tile.active:pointerover">
      <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AppNavActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AppNavActiveTextBrush}"/>
    </Style>

    <Style Selector="Button.flutter-tile.favorite">
      <Setter Property="BorderBrush" Value="#C4A23A"/>
      <Setter Property="BorderThickness" Value="1.5"/>
    </Style>

    <Style Selector="Button.flutter-tile.favorite:pointerover">
      <Setter Property="BorderBrush" Value="#D4AF37"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="10" RowSpacing="10">
    <!-- Header -->
    <Border Grid.Row="0" Classes="flutter-card">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <TextBlock Text="{Binding [IpaTitle], Source={StaticResource Loc}}"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
      <Button Content="{Binding CurrentAccentDisplay}"
              Grid.Column="1"
              Command="{Binding SwitchAccentCommand}"
              Classes="flutter-secondary"
              ToolTip.Tip="{Binding [AccentSwitchTooltip], Source={StaticResource Loc}}"/>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid x:Name="IpaMainContentGrid" Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="10" Classes="ipa-main-content">
      <!-- Phoneme Lists -->
      <ScrollViewer x:Name="PhonemeListScrollViewer" Grid.Column="0" Classes="phoneme-list-panel" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
          <!-- Batch Favorite Buttons -->
          <Border Classes="flutter-card" Padding="8,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
              <TextBlock Text="★" FontSize="16" VerticalAlignment="Center" Foreground="#B88900" Margin="0,0,4,0"/>
              <Button Content="{Binding [FavToggleVowels], Source={StaticResource Loc}}"
                      Command="{Binding ToggleFavoriteVowelsCommand}"
                      Classes="flutter-secondary"
                      Classes.active="{Binding AllVowelsFavorited}"
                      FontSize="13" Padding="10,5" MinHeight="0" MinWidth="0"/>
              <Button Content="{Binding [FavToggleDiphthongs], Source={StaticResource Loc}}"
                      Command="{Binding ToggleFavoriteDiphthongsCommand}"
                      Classes="flutter-secondary"
                      Classes.active="{Binding AllDiphthongsFavorited}"
                      FontSize="13" Padding="10,5" MinHeight="0" MinWidth="0"/>
              <Button Content="{Binding [FavToggleConsonants], Source={StaticResource Loc}}"
                      Command="{Binding ToggleFavoriteConsonantsCommand}"
                      Classes="flutter-secondary"
                      Classes.active="{Binding AllConsonantsFavorited}"
                      FontSize="13" Padding="10,5" MinHeight="0" MinWidth="0"/>
              <Button Content="{Binding [FavClearAll], Source={StaticResource Loc}}"
                      Command="{Binding ClearAllFavoritesCommand}"
                      Classes="flutter-secondary"
                      FontSize="13" Padding="10,5" MinHeight="0" MinWidth="0"/>
            </StackPanel>
          </Border>

          <!-- Vowels -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Vowels], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Vowels}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile ipa-symbol-button"
                      Classes.active="{Binding IsSelected}"
                      Classes.favorite="{Binding IsFavorite}"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>

          <!-- Diphthongs -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Diphthongs], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Diphthongs}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile ipa-symbol-button"
                      Classes.active="{Binding IsSelected}"
                      Classes.favorite="{Binding IsFavorite}"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>

          <!-- Consonants -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Consonants], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Consonants}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile ipa-symbol-button"
                      Classes.active="{Binding IsSelected}"
                      Classes.favorite="{Binding IsFavorite}"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Phoneme Detail Panel -->
            <Border x:Name="DetailPanelBorder" Grid.Column="1" 
              Classes="flutter-card ipa-detail-panel"
              IsVisible="{Binding SelectedPhoneme, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ScrollViewer>
          <StackPanel Spacing="10">
            <Grid>
                    <Button Classes="phoneme-hero ipa-symbol-button"
                      Command="{Binding PlayPhonemeCommand}"
                      CommandParameter="{Binding SelectedPhoneme}">
                <TextBlock Text="{Binding SelectedPhoneme.Symbol}"
                     FontSize="56"
                       FontWeight="Normal"
                           Classes="ipa-symbol"/>
              </Button>

                    <Button Content="{Binding IsFavorite, Converter={StaticResource FavoriteButtonConverter}}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Classes="favorite-toggle"
                      Classes.active="{Binding IsFavorite}"
                      Command="{Binding ToggleFavoriteCommand}"/>
            </Grid>

            <TextBlock Text="{Binding SelectedPhoneme.Description}" 
                       TextWrapping="Wrap"
                       FontSize="14"/>

            <TextBlock Text="{Binding [ExampleWords], Source={StaticResource Loc}}" 
                       FontSize="16" 
                       FontWeight="SemiBold"
                       Margin="0,10,0,5"/>

            <ItemsControl ItemsSource="{Binding SelectedPhoneme.ExampleWords}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Classes="flutter-word word-chip"
                      Classes.playing="{Binding IsPlaying}"
                      Command="{Binding #Root.DataContext.PlayWordCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Word}" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding IpaTranscription}" Classes="ipa-symbol ipa-transcription" FontSize="13" Opacity="0.76"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
