<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.IpaChartView"
             x:Name="Root"
             x:CompileBindings="False"
             x:DataType="vm:IpaChartViewModel">

  <Grid RowDefinitions="Auto,*" Margin="10" RowSpacing="10">
    <!-- Header -->
    <Border Grid.Row="0" Classes="flutter-card">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <TextBlock Text="{Binding [IpaTitle], Source={StaticResource Loc}}"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>
      <Button Content="{Binding CurrentAccent}"
              Grid.Column="1"
              Command="{Binding SwitchAccentCommand}"
              Classes="flutter-secondary"
              ToolTip.Tip="{Binding [AccentSwitchTooltip], Source={StaticResource Loc}}"/>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="10">
      <!-- Phoneme Lists -->
      <ScrollViewer Grid.Column="0">
        <StackPanel Spacing="12">
          <!-- Vowels -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Vowels], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Vowels}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>

          <!-- Diphthongs -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Diphthongs], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Diphthongs}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>

          <!-- Consonants -->
          <Border Classes="flutter-card">
            <StackPanel>
            <TextBlock Text="{Binding [Consonants], Source={StaticResource Loc}}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding Consonants}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Symbol}"
                      Classes="flutter-tile"
                      Command="{Binding #Root.DataContext.SelectPhonemeCommand}"
                          CommandParameter="{Binding}"
                          FontSize="24"
                          Margin="5"
                          ToolTip.Tip="{Binding Description}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Phoneme Detail Panel -->
      <Border Grid.Column="1" 
              Classes="flutter-card"
              IsVisible="{Binding SelectedPhoneme, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ScrollViewer>
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding SelectedPhoneme.Symbol}" 
                       FontSize="48" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            
                <Button Content="{Binding [PlaySound], Source={StaticResource Loc}}"
                  Classes="flutter-primary"
                    Command="{Binding PlayPhonemeCommand}"
                    CommandParameter="{Binding SelectedPhoneme}"
                    HorizontalAlignment="Stretch"
                  />

            <TextBlock Text="{Binding SelectedPhoneme.Description}" 
                       TextWrapping="Wrap"
                       FontSize="14"/>

            <Button Content="{Binding IsFavorite, Converter={StaticResource FavoriteButtonConverter}}"
                  Classes="flutter-secondary"
                    Command="{Binding ToggleFavoriteCommand}"
                  HorizontalAlignment="Stretch"/>

            <TextBlock Text="{Binding [ExampleWords], Source={StaticResource Loc}}" 
                       FontSize="16" 
                       FontWeight="SemiBold"
                       Margin="0,10,0,5"/>

            <ItemsControl ItemsSource="{Binding SelectedPhoneme.ExampleWords}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button HorizontalAlignment="Stretch"
                        Margin="0,3"
                      Classes="flutter-word"
                      Classes.playing="{Binding IsPlaying}"
                      Command="{Binding #Root.DataContext.PlayWordCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel>
                      <TextBlock Text="{Binding Word}" FontSize="16" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding IpaTranscription}" FontSize="14" Opacity="0.7"/>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Placeholder when no phoneme selected -->
      <Border Grid.Column="1" 
              Classes="flutter-card"
              IsVisible="{Binding SelectedPhoneme, Converter={x:Static ObjectConverters.IsNull}}">
        <TextBlock Text="{Binding [SelectPhonemeHint], Source={StaticResource Loc}}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Opacity="0.6"
                   TextWrapping="Wrap"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
