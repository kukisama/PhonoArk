<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             xmlns:controls="using:Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.ExamHistoryView"
             x:Name="Root"
             x:CompileBindings="False"
             x:DataType="vm:ExamHistoryViewModel">

  <UserControl.Styles>
    <Style Selector="UserControl.phone-landscape TextBlock.history-summary-item">
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="UserControl.phone-landscape Button.examattemptcard">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="6,3"/>
    </Style>
  </UserControl.Styles>

  <Grid x:Name="HistoryRootGrid" Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*" ColumnDefinitions="*" RowSpacing="10" ColumnSpacing="12">
    <TextBlock x:Name="HistoryTitleText" Grid.Row="0" Grid.Column="0"
               Text="{Binding [ExamHistory], Source={StaticResource Loc}}" 
               Classes="flutter-title"
               Margin="0,0,0,10"/>

    <Border x:Name="SummaryBorder" Grid.Row="1" Grid.Column="0"
            Classes="flutter-card"
            Margin="0,0,0,4">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
          <TextBlock x:Name="AvgScoreLabelText" Text="{Binding [AverageScore], Source={StaticResource Loc}}"
                     FontSize="18"
                     FontWeight="SemiBold"/>
          <TextBlock x:Name="AvgScoreValueText" Text="{Binding AverageScore, StringFormat='{}{0:F1}%'}"
                     FontSize="18"
                     FontWeight="SemiBold"/>
        </StackPanel>

        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" ItemSpacing="6" LineSpacing="2">
          <TextBlock Classes="history-summary-item" Text="{Binding [AttemptSummary], Source={StaticResource Loc}}"
                     Opacity="0.8"/>
          <TextBlock Classes="history-summary-item" Text="{Binding TotalAttempts}" FontWeight="SemiBold"/>
          <TextBlock Classes="history-summary-item" Text="{Binding [WrongAttempts], Source={StaticResource Loc}}" Opacity="0.8"/>
          <TextBlock Classes="history-summary-item" Text="{Binding WrongAttempts}" FontWeight="SemiBold"/>
          <TextBlock Classes="history-summary-item" Text="{Binding [WrongRate], Source={StaticResource Loc}}" Opacity="0.8"/>
          <TextBlock Classes="history-summary-item" Text="{Binding WrongRate, StringFormat='{}{0:F1}%'}" FontWeight="SemiBold"/>
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border x:Name="FilterBorder" Grid.Row="2" Grid.Column="0" Classes="flutter-card" Margin="0,0,0,4">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
        <CheckBox Grid.Column="0"
                  Content="{Binding [ShowWrongOnly], Source={StaticResource Loc}}"
                  IsChecked="{Binding ShowWrongOnly}"
                  VerticalAlignment="Center"/>
        <Button Grid.Column="1"
                Content="{Binding [ClearHistory], Source={StaticResource Loc}}"
                Classes="flutter-secondary"
                Command="{Binding ClearHistoryCommand}"/>
      </Grid>
    </Border>

    <controls:Expander x:Name="ErrorStatsExpander"
                     Grid.Row="3"
               Grid.Column="0"
                       IsExpanded="{Binding IsErrorStatsExpanded}"
                       Classes="flutter-card"
                       Header="{Binding [PhonemeErrorStats], Source={StaticResource Loc}}">
      <ScrollViewer MaxHeight="200"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">
          <ItemsControl ItemsSource="{Binding ErrorStats}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,2,0,2">
                  <TextBlock Grid.Column="0" Text="{Binding PhonemeSymbol}" FontWeight="SemiBold"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding ErrorCount}" Opacity="0.85"/>
                    <TextBlock Text="{Binding [Times], Source={StaticResource Loc}}" Opacity="0.85"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding [NoErrorStatsHint], Source={StaticResource Loc}}"
                     IsVisible="{Binding !HasErrorStats}"
                     Opacity="0.65"/>
        </StackPanel>
      </ScrollViewer>
    </controls:Expander>

    <ScrollViewer x:Name="SessionsScrollViewer" Grid.Row="4" Grid.Column="0">
      <ItemsControl ItemsSource="{Binding Sessions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                  BorderThickness="0"
                  Classes="flutter-card"
                    Margin="0,0,0,10">
              <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="{Binding SessionTitle}" FontSize="16" FontWeight="SemiBold"/>
                  <TextBlock Text="•" Opacity="0.5"/>
                  <TextBlock Text="{Binding [CorrectLabel], Source={StaticResource Loc}}" Opacity="0.7"/>
                  <TextBlock Text="{Binding CorrectCount}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding [WrongAttempts], Source={StaticResource Loc}}" Opacity="0.7"/>
                  <TextBlock Text="{Binding WrongCount}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding [NumberOfQuestions], Source={StaticResource Loc}}" Opacity="0.7"/>
                  <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Cards}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" ItemWidth="104" ItemHeight="50"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Height="38"
                              Width="92"
                              MinWidth="92"
                              MaxWidth="92"
                              Margin="6"
                              HorizontalAlignment="Left"
                              HorizontalContentAlignment="Center"
                              Content="{Binding CardText}"
                              ToolTip.Tip="{Binding CardToolTip}"
                              Command="{Binding #Root.DataContext.LoadAttemptDetailCommand}"
                              CommandParameter="{Binding}"
                              Background="{Binding CardBackground}"
                              BorderBrush="{Binding CardBorderBrush}"
                              Foreground="{Binding CardForeground}"
                              Classes="examattemptcard">
                        <Button.Flyout>
                          <Flyout Placement="Right" ShowMode="Transient">
                            <Border Classes="flutter-card" MaxWidth="360">
                              <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                  <TextBlock Text="{Binding [QuestionLabel], Source={StaticResource Loc}}" FontWeight="SemiBold"/>
                                  <TextBlock Text="{Binding QuestionOrder}" FontWeight="SemiBold"/>
                                  <TextBlock Text="•" Opacity="0.5"/>
                                  <TextBlock Text="{Binding [Phoneme], Source={StaticResource Loc}}" Opacity="0.8"/>
                                  <TextBlock Text="{Binding PhonemeSymbol}" FontWeight="SemiBold"/>
                                </StackPanel>

                                <TextBlock Text="{Binding ResultText}" FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding [YourAnswer], Source={StaticResource Loc}}" Opacity="0.8"/>
                                <TextBlock Text="{Binding UserAnswer}" TextWrapping="Wrap"/>

                                <TextBlock Text="{Binding [CorrectAnswerLabel], Source={StaticResource Loc}}" Opacity="0.8"/>
                                <TextBlock Text="{Binding CorrectAnswer}" TextWrapping="Wrap"/>
                              </StackPanel>
                            </Border>
                          </Flyout>
                        </Button.Flyout>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <TextBlock x:Name="NoHistoryText"
            Grid.Row="4"
           Grid.Column="0"
               Text="{Binding [NoExamHistoryHint], Source={StaticResource Loc}}"
               IsVisible="{Binding !HasAttemptItems}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="16"
               Opacity="0.6"/>
  </Grid>
</UserControl>
