<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PhonoArk.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhonoArk.Views.FavoritesView"
             x:Name="Root"
             x:CompileBindings="False"
             x:DataType="vm:FavoritesViewModel">

  <Grid x:Name="FavoritesRootGrid" Margin="20" RowDefinitions="Auto,*" ColumnDefinitions="*" RowSpacing="10" ColumnSpacing="12">
    <StackPanel x:Name="FavoritesFilterPanel" Grid.Row="0" Grid.Column="0" Spacing="10" Margin="0,0,0,4">
      <TextBlock Text="{Binding [FavoritePhonemes], Source={StaticResource Loc}}" Classes="flutter-title"/>

      <Border x:Name="GroupFilterBorder" Classes="flutter-card">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
        <TextBlock Grid.Column="0"
                   Text="{Binding [Group], Source={StaticResource Loc}}"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <ComboBox Grid.Column="1"
                  Classes="flutter-input"
                  ItemsSource="{Binding Groups}"
                  SelectedItem="{Binding SelectedGroup}"
                  HorizontalAlignment="Stretch"/>
      </Grid>
      </Border>

      <Border x:Name="ClearAllBorder" Classes="flutter-card" Margin="0,0,0,2">
        <Button Content="{Binding [ClearAll], Source={StaticResource Loc}}"
                Classes="flutter-secondary"
                Command="{Binding ClearAllCommand}"
                HorizontalAlignment="Stretch"/>
      </Border>
    </StackPanel>

    <ScrollViewer x:Name="FavoritesListScrollViewer" Grid.Row="1" Grid.Column="0">
      <ItemsControl ItemsSource="{Binding Favorites}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                  BorderThickness="0"
                  Classes="flutter-card"
                    Margin="0,0,0,10">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding PhonemeSymbol}"
                           FontSize="32"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding GroupName}" FontSize="14" Opacity="0.7"/>
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding [Added], Source={StaticResource Loc}}"
                               FontSize="12"
                               Opacity="0.5"/>
                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:g}'}"
                               FontSize="12"
                               Opacity="0.5"/>
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="2"
                        Content="{Binding [Remove], Source={StaticResource Loc}}"
                        Classes="flutter-secondary"
                        Command="{Binding #Root.DataContext.RemoveFavoriteCommand}"
                        CommandParameter="{Binding}"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <TextBlock x:Name="NoFavoritesText"
           Grid.Row="1"
           Grid.Column="0"
               Text="{Binding [NoFavoritesHint], Source={StaticResource Loc}}"
               IsVisible="{Binding !Favorites.Count}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="16"
               Opacity="0.6"/>
  </Grid>
</UserControl>
